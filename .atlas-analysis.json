  "keyFeatures": [
    "Personalized news feed curated from thousands of sources via NewsAPI.ai based on user-defined interests",
    "AI assistant named Quill powered by LangChain and OpenAI for conversational news exploration",
    "Daily email digests with AI-generated summaries delivered at user-preferred times and timezones",
    "Semantic vector search over articles using OpenAI embeddings stored in Supabase",
    "Google OAuth authentication with Supabase for secure, passwordless sign-in",
    "Onboarding flow for selecting interests and configuring digest delivery preferences",
    "Cron-based automation for creating and sending scheduled digests with fallback cache support"
  ],
  "publicApiSurface": [
